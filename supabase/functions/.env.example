# Edge Function secrets
# Copy to .env and fill in values. Never commit .env.
#
# --- Local development (supabase functions serve) ---
#   supabase functions serve --env-file ../../.env.local
#   Or: supabase functions serve --env-file ./supabase/functions/.env
#
# --- Self-hosted / open-source Supabase (no Dashboard Secrets UI) ---
#   Load this file in the environment of your Edge Functions runtime:
#   - In docker-compose: for the "functions" service, add env_file or environment:
#       env_file: .env
#     or
#       environment:
#         - GOOGLE_AI_API_KEY=your_key_here
#   - Or ensure the process that runs Edge Functions reads GOOGLE_AI_API_KEY from its env.
#
# --- Supabase Cloud (hosted) ---
#   Dashboard → Project Settings → Edge Functions → Secrets

GOOGLE_AI_API_KEY=
# Or use: GEMINI_API_KEY=

# Transactional + auth email via AWS SES SMTP (send-auth-email hook replaces GoTrue SMTP when enabled)
# Set on the FUNCTIONS container (not auth). GoTrue-style names are accepted as fallbacks:
# SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_ADMIN_EMAIL
SES_SMTP_HOST=
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASSWORD=
# Optional override when email_settings.from_address is empty (default: system@thetalentapp.io)
EMAIL_FROM=system@thetalentapp.io

# Auth Send Email Hook secret — generate in Dashboard → Auth → Hooks → Send Email
# Format: v1,whsec_<base64_secret> (32–88 chars). Also set in config.toml for local dev.
SEND_AUTH_EMAIL_HOOK_SECRET=

# Public app URL for email image links and CTAs (e.g. https://talent.sparxitsolutions.com)
PUBLIC_APP_URL=

# Optional: marketing/OSS site for email footer (defaults to PUBLIC_APP_URL or GitHub)
# PUBLIC_MARKETING_URL=https://github.com/vikashsparxit/the-talent-app

# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Supabase injects these when deployed; for local serve they come from supabase start
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

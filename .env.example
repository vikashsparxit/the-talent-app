# The Talent App — frontend environment (Vite)
#
# Copy to .env.dev for local development:
#   cp .env.example .env.dev
#
# npm run dev uses Vite mode "dev", which loads .env.dev (and .env.dev.local if present).
# Never commit real keys. See docs/LOCAL_SETUP_GUIDE.md for full setup.

# Required — Supabase project URL (cloud or self-hosted)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Required — Supabase anon / publishable key (safe for browser; RLS enforces access)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional — local dev only: Gemini API key sent to edge functions when remote secrets are unset
# Only used when running vite dev or on localhost. Do not set in production builds.
# VITE_GEMINI_API_KEY=your-google-ai-api-key

# Edge function secrets (SES_SMTP_*, SEND_AUTH_EMAIL_HOOK_SECRET) are NOT set here — configure via supabase/functions/.env.example
